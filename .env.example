# ====== Обязательные переменные для VPS (Node) ======

# Публичный адрес сайта (без слэша в конце). Используется auth и ссылками.
APP_URL=https://shop.neon-ek.ru

# Секрет для подписи сессий Better Auth. Сгенерируйте: openssl rand -base64 32
BETTER_AUTH_SECRET=замените_на_случайную_строку

# PostgreSQL. Пример: postgres://user:pass@localhost:5432/neon_ek
DATABASE_URL=postgres://neon:password@localhost:5432/neon_ek

# ====== Интеграция с Битрикс24 (приём заказов как сделки) ======
# Входящий вебхук из Битрикс24 с правами crm + catalog.
# Формат: https://ВАШ_ПОРТАЛ.bitrix24.ru/rest/USER_ID/КОД_ВЕБХУКА/
BITRIX24_WEBHOOK_URL=https://ваш-портал.bitrix24.ru/rest/1/xxxxxxxxxxxxx/

# ====== Прочее ======
NODE_ENV=production
PORT=3000
